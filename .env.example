# ============================================================
#  ARKA Intelligence Center — Variables de entorno
#  Para desarrollo local: copia este archivo como .env
#  Para Vercel: copia cada variable en Settings → Environment Variables
#  IMPORTANTE: todas las variables del frontend DEBEN empezar con VITE_
# ============================================================

# ── RELAY (obtener tras deploy en Railway) ──────────────────
VITE_WS_RELAY_URL=https://TU-RELAY.up.railway.app
VITE_RELAY_SECRET=arka2026secret

# ── MARKETS ────────────────────────────────────────────────
VITE_FINNHUB_API_KEY=tu_finnhub_key
VITE_FRED_API_KEY=tu_fred_key
VITE_EIA_API_KEY=tu_eia_key
VITE_ALPHA_VANTAGE_API_KEY=tu_alphavantage_key

# ── NOTICIAS ───────────────────────────────────────────────
VITE_NEWSAPI_KEY=tu_newsapi_key
VITE_GUARDIAN_API_KEY=tu_guardian_key
VITE_NYT_API_KEY=tu_nyt_key

# ── AI / LLM ───────────────────────────────────────────────
VITE_GROQ_API_KEY=tu_groq_key
VITE_OPENROUTER_API_KEY=tu_openrouter_key
VITE_ANTHROPIC_API_KEY=tu_anthropic_key

# ── TRACKING / GEO ─────────────────────────────────────────
VITE_AISSTREAM_API_KEY=tu_aisstream_key
VITE_OPENSKY_CLIENT_ID=tu_opensky_id
VITE_OPENSKY_CLIENT_SECRET=tu_opensky_secret
VITE_AVIATIONSTACK_KEY=tu_aviationstack_key
VITE_NASA_FIRMS_API_KEY=tu_nasa_firms_key
VITE_CLOUDFLARE_API_TOKEN=tu_cloudflare_token

# ── NOTICIAS / PREDICCIONES ────────────────────────────────
VITE_METACULUS_API_KEY=tu_metaculus_key
VITE_MAPBOX_TOKEN=tu_mapbox_token
VITE_HAPI_APP_IDENTIFIER=tu_hapi_identifier
VITE_BROADCASTIFY_API_KEY=tu_broadcastify_key

# ── MONITOREO ──────────────────────────────────────────────
VITE_SENTRY_DSN=tu_sentry_dsn

# ── PÚBLICAS (sin key real, dejar como están) ───────────────
# GDELT, Polymarket, USGS, UNHCR, World Bank, IMF, BIS
# Estas APIs no requieren key — el código las llama directo
